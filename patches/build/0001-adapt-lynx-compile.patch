+        values[key] = val.replace('\\n', '\n')
+    unused_values = set(values.keys())
+
+    # Matches e.g. '${FOO}' or '@FOO@' and captures FOO in group 1 or 2.
+    var_re = re.compile(r'\$\{([^}]*)\}|@([^@]*)@')
+
