+            unused_values.discard(var)
+        out_lines.append(in_line)
+
+    if unused_values:
+        print('unused values args:', file=sys.stderr)
+        print('    ' + '\n    '.join(unused_values), file=sys.stderr)
+        return 1
+
+    output = ''.join(out_lines)
+
+    leftovers = var_re.findall(output)
