From 5a1c60478d03cc100c4c4d6cd915bf5d9ce6bb4a Mon Sep 17 00:00:00 2001
From: RobinWu <46469310+RobinWuu@users.noreply.github.com>
Date: Thu, 19 Mar 2026 15:43:50 +0800
Subject: [PATCH] Impl lynx_module set for lynxnodemodule.

Patch-Dir: lynxtron/patches/lynx
Patch-Filename: 0006-Bugfix-Impl-lynx_module-set-for-lynxnodemodule.patch
---
 lynx/core/runtime/js/bindings/modules/lynx_module.cc | 12 ++++++++++++
 lynx/core/runtime/js/bindings/modules/lynx_module.h  |  3 +++
 2 files changed, 15 insertions(+)

diff --git a/lynx/core/runtime/js/bindings/modules/lynx_module.cc b/lynx/core/runtime/js/bindings/modules/lynx_module.cc
index 57da4ae56..e111452ca 100644
--- a/lynx/core/runtime/js/bindings/modules/lynx_module.cc
+++ b/lynx/core/runtime/js/bindings/modules/lynx_module.cc
@@ -103,6 +103,9 @@ Value LynxModule::get(Runtime* runtime, const PropNameID& prop) {
           return lock_module->invokeMethod(*(meta.get()), &rt, args, count);
         });
   } else {
+    if (name_ == "nodejs" && propNameUtf8 == "getExposed") {
+      return Value(*runtime, node_api_);
+    }
     auto attr = this->getAttributeValue(runtime, propNameUtf8);
     if (!attr.isUndefined()) {
       return attr;
@@ -120,6 +123,15 @@ Value LynxModule::get(Runtime* runtime, const PropNameID& prop) {
     return Value::undefined();
   }
 }
+
+void LynxModule::set(Runtime* runtime, const PropNameID& prop, const Value& value) {
+  std::string propNameUtf8 = prop.utf8(*runtime);
+  if (name_ == "nodejs" && propNameUtf8 == "getExposed") {
+    node_api_ = Value(*runtime, value);
+    return;
+  }
+}
+
 }  // namespace js
 }  // namespace runtime
 }  // namespace lynx
diff --git a/lynx/core/runtime/js/bindings/modules/lynx_module.h b/lynx/core/runtime/js/bindings/modules/lynx_module.h
index 39d9763ad..b88c7d5ed 100644
--- a/lynx/core/runtime/js/bindings/modules/lynx_module.h
+++ b/lynx/core/runtime/js/bindings/modules/lynx_module.h
@@ -48,6 +48,8 @@ class LynxModule : public HostObject,
 
   Value get(Runtime* rt, const PropNameID& prop) override;
 
+  void set(Runtime* rt, const PropNameID& prop, const Value& value) override;
+
   const std::string name_;
   // Public for NetworkInterceptor. When Refactor network finished, protected
   // this.
@@ -87,6 +89,7 @@ class LynxModule : public HostObject,
 
  protected:
   std::unordered_map<std::string, std::shared_ptr<MethodMetadata>> methodMap_;
+  Value node_api_ = Value::undefined();
   std::shared_ptr<GroupInterceptor> group_interceptor_;
 #if ENABLE_TESTBENCH_RECORDER
   ALLOW_UNUSED_TYPE int64_t record_id_ = 0;
-- 
2.49.0

