#ifndef ELECTRON_LYNXTRON_VERSION_H
#define ELECTRON_LYNXTRON_VERSION_H

#define ELECTRON_MAJOR_VERSION $major
#define ELECTRON_MINOR_VERSION $minor
#define ELECTRON_PATCH_VERSION $patch
#if $has_prerelease
#define ELECTRON_PRE_RELEASE_VERSION -$prerelease
#endif

#ifndef ELECTRON_PRE_RELEASE_VERSION
#define LYNXTRON_VERSION_STRING "$major.$minor.$patch"
#else
#define LYNXTRON_VERSION_STRING "$major.$minor.$patch-$prerelease"
#endif

#define LYNXTRON_VERSION "v" LYNXTRON_VERSION_STRING

#endif  // ELECTRON_LYNXTRON_VERSION_H
