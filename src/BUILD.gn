asar("default_app_asar") {
  deps = [
    ":default_app_js",
    ":default_app_static",
  ]
  deps += lynxtron_asar_extra_deps

  root = "$target_gen_default_app_js/lynxtron/default_app"
  sources = get_target_outputs(":default_app_js") +
            get_target_outputs(":default_app_static")
  outputs = [ "$root_out_dir/resources/default_app.asar" ]
}

node_action("default_app_asar_win_integrity") {
  hash_files = get_target_outputs(":default_app_asar_header_hash")

  deps = [ ":default_app_asar_header_hash" ]
  inputs = hash_files
  outputs = [ "$target_gen_dir/win-resources/default_app.asar.integrity.json" ]

  script = "script/gn-win-asar-integrity.js"
  args = [
    "resources/default_app.asar",
    rebase_path(hash_files[0]),
    rebase_path(outputs[0]),
  ]
}

templated_file("lynxtron_win_rc") {
  deps = [
    ":default_app_asar_win_integrity",
    ":lynxtron_version_args",
  ]

  template = "build/templates/lynxtron_rc.tmpl"
  output = "$target_gen_dir/win-resources/lynxtron.rc"

  inputs = get_target_outputs(":default_app_asar_win_integrity")
  args_files = get_target_outputs(":lynxtron_version_args")
}

