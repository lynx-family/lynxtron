if (is_mac) {
  lynxtron_mac_bundle_id = "com.lynxjs.Lynxtron"
  lynxtron_framework_name = "$lynxtron_product_name Framework"

  action("lynxtron_app_lproj_dirs") {
    outputs = []
    foreach(locale, lynxtron_mac_locales_as_apple_outputs) {
      outputs += [ "$target_gen_dir/app_lproj_dirs/$locale.lproj" ]
    }

    script = "build/mac/make_locale_dirs.py"
    args = rebase_path(outputs)
  }

  foreach(locale, lynxtron_mac_locales_as_apple_outputs) {
    bundle_data("lynxtron_app_locale_${locale}_bundle_data") {
      sources = [ "$target_gen_dir/app_lproj_dirs/$locale.lproj" ]
      outputs = [ "{{bundle_resources_dir}}/{{source_file_part}}" ]
      public_deps = [ ":lynxtron_app_lproj_dirs" ]
    }
  }

  group("lynxtron_app_locales_bundle_data") {
    public_deps = []
    foreach(locale, lynxtron_mac_locales_as_apple_outputs) {
      public_deps += [ ":lynxtron_app_locale_${locale}_bundle_data" ]
    }
  }

  mac_framework_bundle("lynxtron_framework") {
    # TODO(Guo Xi): using macro defines
    output_name = "Lynxtron Framework"
    framework_version = "1.0"
    framework_contents = [
      "Resources",
      "Libraries",
    ]

    public_deps = [ ":lynxtron_lib" ]

    deps = [
      ":lynxtron_framework_resources",
      "//base",
      "//third_party/node:libnode",
    ]
    configs += lynxtron_lib_extra_configs

    info_plist = "shell/common/resources/mac/Info.plist"

    extra_substitutions = [
      "LYNXTRON_BUNDLE_ID=$lynxtron_mac_bundle_id.framework",
      "LYNXTRON_VERSION=$lynxtron_version",
    ]

    frameworks = []

    include_dirs = [ "." ]

    ldflags = [
      "-Wl,-install_name,@rpath/$output_name.framework/$output_name",
      # TOOD(Guo Xi): generate libuv.a
      # Required for exporting all symbols of libuv.
      # "-Wl,-force_load,obj/third_party/node/deps/uv/libuv.a",
    ]

    ldflags += [
      "-Wl,-dead_strip",
      "-Wl,-dead_strip_dylibs",
    ]

    frameworks += [
      "Carbon.framework",
      "Cocoa.framework",
      "CoreVideo.framework",
      "IOSurface.framework",
      "Metal.framework",
      "QuartzCore.framework",
      "OpenGL.framework",
      "JavaScriptCore.framework",
      "WebKit.framework",
    ]
  }

  bundle_data("lynxtron_framework_resources") {
    public_deps = []
    sources = []

    if (icu_use_data_file) {
      sources += [ "$root_out_dir/icudtl.dat" ]
      public_deps += [ "//third_party/icu:icudata" ]
    }
    if (v8_use_external_startup_data) {
      public_deps += [ "//v8" ]
      sources += [ "$root_out_dir/snapshot_blob.bin" ]

      # TODO(Guo Xi): review use_v8_context_snapshot
      # if (use_v8_context_snapshot) {
      #   sources += [ "$root_out_dir/$v8_context_snapshot_filename" ]
      #   public_deps += [ "//tools/v8_context_snapshot" ]
      # } else {
      #   sources += [ "$root_out_dir/snapshot_blob.bin" ]
      # }
    }
    outputs = [ "{{bundle_resources_dir}}/{{source_file_part}}" ]
  }

  bundle_data("lynxtron_app_framework_bundle_data") {
    sources = [ "$root_out_dir/$lynxtron_framework_name.framework" ]

    outputs = [ "{{bundle_contents_dir}}/Frameworks/{{source_file_part}}" ]
    public_deps = [ ":lynxtron_framework+link" ]
  }

  bundle_data("lynxtron_app_resources") {
    public_deps = [
      ":default_app_asar",
      ":lynxtron_app_locales_bundle_data",
    ]
    sources = [
      "$root_out_dir/resources/default_app.asar",
      "shell/app/resources/mac/lynxtron.icns",
    ]

    public_deps += lynxtron_app_resources_deps
    outputs = [ "{{bundle_resources_dir}}/{{source_file_part}}" ]
  }

  asar_hashed_info_plist("lynxtron_app_plist") {
    keys = [ "DEFAULT_APP_ASAR_HEADER_SHA" ]
    hash_targets = [ ":default_app_asar_header_hash" ]
    plist_file = "shell/app/resources/mac/Info.plist"
  }

  mac_app_bundle("lynxtron_app") {
    output_name = "lynxtron"

    include_dirs = [ "." ]

    deps = [
      ":lynxtron_app_framework_bundle_data",
      ":lynxtron_app_plist",
      ":lynxtron_app_resources",
      ":lynxtron_framework+link",
      "//base/allocator:early_zone_registration_apple",
    ]

    deps += lynxtron_app_extra_deps

    info_plist_target = ":lynxtron_app_plist"

    sources = [ "shell/app/main_mac.cc" ]

    ldflags = [
      "-rpath",
      "@executable_path/../Frameworks",
    ]

    # TODO(Guo Xi): The bundle ID in info.plist needs to be replaced.
    extra_substitutions = [
      "LYNXTRON_BUNDLE_ID=$lynxtron_mac_bundle_id",
      "LYNXTRON_VERSION=$lynxtron_version",
    ]
  }

  action("copy_app_to_package") {
    deps = [ ":lynxtron_app" ]
    script = "tools/copy_to_package.py"
    inputs = [ "$root_out_dir/lynxtron.app" ]
    outputs = [ "$root_out_dir/.copied_to_package_$target_cpu" ]
    args = [
      rebase_path("$root_out_dir/lynxtron.app", root_build_dir),
      rebase_path("//src/packages/lynxtron/dist/darwin/$target_cpu",
                  root_build_dir),
      rebase_path("$root_out_dir/.copied_to_package_$target_cpu",
                  root_build_dir),
    ]
  }
}

if (is_win) {
  group("lynxtron_win32_resources") {
    public_deps = [
      ":lynxtron_win_rc",
      ":lynxtron_win_resource_files",
    ]
  }

  windows_manifest("lynxtron_app_manifest") {
    sources = [
      "shell/app/resources/win/disable_window_filtering.manifest",
      "shell/app/resources/win/dpi_aware.manifest",
      as_invoker_manifest,
      common_controls_manifest,
      default_compatibility_manifest,
    ]
  }

  executable("lynxtron_app") {
    output_name = "lynxtron"
    configs -= [ "//build/config/win:console" ]
    configs += [
      "//build/config/win:windowed",
      "//build/config/win:delayloads",
    ]

    deps = [
      ":default_app_asar",
      ":lynxtron_app_manifest",
      ":lynxtron_shared",
      ":lynxtron_win32_resources",
      "//base",
    ]

    include_dirs = [ "." ]

    sources = [ "shell/app/main_win.cc" ]
    sources += get_target_outputs(":lynxtron_win_rc")

    ldflags = [ "/DEF:" + rebase_path("build/lynxtron.def", root_build_dir) ]
    if (current_cpu == "x86") {
      # Set the initial stack size to 0.5MiB, instead of the 1.5MiB needed by
      # Chrome's main thread. This saves significant memory on threads (like
      # those in the Windows thread pool, and others) whose stack size we can
      # only control through this setting. Because Chrome's main thread needs
      # a minimum 1.5 MiB stack, the main thread (in 32-bit builds only) uses
      # fibers to switch to a 1.5 MiB stack before running any other code.
      ldflags += [ "/STACK:0x80000" ]
    } else {
      # Increase the initial stack size. The default is 1MB, this is 8MB.
      ldflags += [ "/STACK:0x800000" ]
    }

    inputs = [
      "shell/app/resources/win/lynxtron.ico",
      "build/lynxtron.def",
    ]
    data = [
      "$root_out_dir/resources/default_app.asar",
      "$root_out_dir/lynx_core.js",
      "$root_out_dir/lynx_core_dev.js",
      "$root_out_dir/icudtl.dat",
      "$root_out_dir/parfait.dll",
    ]
  }

  shared_library("lynxtron_shared") {
    deps = [ ":lynxtron_lib" ]

    configs += lynxtron_lib_extra_configs
    configs += [ "//build/config/win:delayloads" ]
    libs = [
      "Comctl32.lib",
      "Wintrust.lib",
      "wtsapi32.lib",
      "Dwmapi.lib",
      "WebView2LoaderStatic.lib",
      "runtimeobject.lib",
      "propsys.lib",
      "shlwapi.lib",
    ]
    lib_dirs = [ "//third_party/webview2/Microsoft.Web.WebView2.1.0.902.49/build/native/$current_cpu" ]
    output_name = "lynxtron"
    ldflags = []
    if (current_cpu == "x86") {
      # Set the initial stack size to 0.5MiB, instead of the 1.5MiB needed by
      # Chrome's main thread. This saves significant memory on threads (like
      # those in the Windows thread pool, and others) whose stack size we can
      # only control through this setting. Because Chrome's main thread needs
      # a minimum 1.5 MiB stack, the main thread (in 32-bit builds only) uses
      # fibers to switch to a 1.5 MiB stack before running any other code.
      ldflags += [ "/STACK:0x80000" ]
    } else {
      # Increase the initial stack size. The default is 1MB, this is 8MB.
      ldflags += [ "/STACK:0x800000" ]
    }
  }
}

template("dist_zip") {
  _runtime_deps_target = "${target_name}__deps"
  _runtime_deps_file =
      "$root_out_dir/gen.runtime/" + get_label_info(target_name, "dir") + "/" +
      get_label_info(target_name, "name") + ".runtime_deps"

  group(_runtime_deps_target) {
    forward_variables_from(invoker,
                           [
                             "deps",
                             "data_deps",
                             "data",
                             "testonly",
                           ])
    write_runtime_deps = _runtime_deps_file
  }

  action(target_name) {
    script = "./build/zip.py"
    deps = [ ":$_runtime_deps_target" ]
    forward_variables_from(invoker,
                           [
                             "outputs",
                             "testonly",
                           ])
    flatten = false
    flatten_relative_to = false
    if (defined(invoker.flatten)) {
      flatten = invoker.flatten
      if (defined(invoker.flatten_relative_to)) {
        flatten_relative_to = invoker.flatten_relative_to
      }
    }
    args = rebase_path(outputs + [ _runtime_deps_file ], root_build_dir) + [
             target_cpu,
             target_os,
             "$flatten",
             "$flatten_relative_to",
           ]
  }
}

dist_zip("lynxtron_dist_zip") {
  data_deps = [
    ":lynxtron_app",
    # ":electron_version_file",
    # ":licenses",
  ]
  deps = data_deps
  outputs = [ "$root_build_dir/dist.zip" ]
}

