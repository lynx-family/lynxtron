  import("//build/config/mac/rules.gni")
  import("//third_party/icu/config.gni")
  import("//v8/gni/v8.gni")

  assert(
      mac_deployment_target == "12.0",
      "Chromium has updated the mac_deployment_target, please update this assert and flag this as a breaking change (docs/breaking-changes.md)")
}

lynxtron_project_name = "lynxtron"
lynxtron_product_name = "Lynxtron"

# TODO(Guo Xi): We need to consider how to generate version numbers, referring to Chrome's approach (as seen in chrome/VERSION)
lynxtron_version = "1.0.0"

declare_args() {
  # Locales used by macOS-specific localized bundle resources. The entries use
  # Chromium locale names and are converted to Apple output names below.
  lynxtron_mac_locales = [
    "en-US",
    "zh-CN",
  ]
}

lynxtron_mac_locales_as_apple_outputs = []
foreach(locale, lynxtron_mac_locales) {
  if (locale == "en-US") {
    lynxtron_mac_locales_as_apple_outputs += [ "en" ]
  } else {
    lynxtron_mac_locales_as_apple_outputs +=
        [ string_replace(locale, "-", "_") ]
  }
}

config("branding") {
  defines = [
    "LYNXTRON_PRODUCT_NAME=\"$lynxtron_product_name\"",
    "LYNXTRON_PROJECT_NAME=\"$lynxtron_project_name\"",
  ]
}

config("lynxtron_lib_config") {
  include_dirs = [ "." ]
  defines = []
  if (enable_trace == "perfetto") {
    defines += [ "ENABLE_TRACE_PERFETTO" ]
  }
  if (is_mac && is_mas_build) {
    defines += [ "MAS_BUILD" ]
  }
}

action("lynxtron_generate_node_defines") {
  script = "build/generate_node_defines.py"

  inputs = [
    "//third_party/node/src/tracing/trace_event_common.h",
    "//third_party/node/src/tracing/trace_event.h",
    "//third_party/node/src/util.h",
  ]

  outputs = [
    "$target_gen_dir/push_and_undef_node_defines.h",
    "$target_gen_dir/pop_node_defines.h",
  ]

  args = [ rebase_path(target_gen_dir) ] + rebase_path(inputs)
}

npm_action("lynxtron_version_args") {
  script = "generate-version-json"

  outputs = [ "$target_gen_dir/lynxtron_version.args" ]

  args = rebase_path(outputs) + [ "$lynxtron_version" ]

  inputs = [ "script/generate-version-json.js" ]
}

templated_file("lynxtron_version_header") {
  deps = [ ":lynxtron_version_args" ]

  template = "build/templates/lynxtron_version.tmpl"
  output = "$target_gen_dir/lynxtron_version.h"

  args_files = get_target_outputs(":lynxtron_version_args")
}

copy("lynxtron_win_resource_files") {
  sources = [
    "shell/app/resources/win/lynxtron.ico",
    "shell/app/resources/win/resource.h",
  ]
  outputs = [ "$target_gen_dir/win-resources/{{source_file_part}}" ]
}

templated_file("lynxtron_version_file") {
  deps = [ ":lynxtron_version_args" ]

  template = "build/templates/version_string.tmpl"
  output = "$root_build_dir/version"

  args_files = get_target_outputs(":lynxtron_version_args")
}

