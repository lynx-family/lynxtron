+
+#ifndef CLAY_SHELL_PLATFORM_DARWIN_MACOS_PLATFORM_OVERLAY_SERVICE_MAC_H_
+#define CLAY_SHELL_PLATFORM_DARWIN_MACOS_PLATFORM_OVERLAY_SERVICE_MAC_H_
+
+#import <Metal/Metal.h>
+#import <QuartzCore/QuartzCore.h>
+
+#include <memory>
+#include <vector>
+
+#include "clay/shell/common/services/compositor/platform_overlay_service.h"
+#include "clay/shell/platform/darwin/macos/framework/Source/FlutterSurface.h"
+#include "clay/shell/platform/embedder/embedder_surface_metal.h"
+
+namespace clay {
+
+// One Metal IOSurface-backed overlay layer rendered above native views.
+// Each instance owns a CALayer sublayer on the Lynx overlay view's layer.
+class PlatformOverlayMac final : public PlatformOverlay,
+                                 private EmbedderSurfaceMetalDelegate {
+ public:
+  PlatformOverlayMac(id<MTLDevice> device,
+                     id<MTLCommandQueue> command_queue,
+                     CALayer* layer);
+  ~PlatformOverlayMac() override;
+
+  // Update the sublayer frame (called from platform/main thread).
+  void UpdateLayerFrame(CGRect frame);
+
+  // Returns the contentsScale set on this overlay's CALayer.
+  CGFloat GetContentsScale() const;
+
+  // PlatformOverlay
+  fml::RefPtr<OutputSurface> GetOutputSurface() const override;
+  void OnSurfaceUpdated() override {}
+
+ private:
+  // EmbedderSurfaceMetalDelegate
+  GPUMTLDeviceHandle GetMTLDevice() const override;
+  GPUMTLCommandQueueHandle GetMTLCommandQueue() const override;
+  GPUMTLTextureInfo GetMTLTexture(const skity::Vec2& frame_size) const override;
+  bool PresentTexture(GPUMTLTextureInfo texture) const override;
+  bool EnablePartialRepaint() const override;
+
+  id<MTLDevice> device_;
+  id<MTLCommandQueue> command_queue_;
+  CALayer* layer_;
+  mutable FlutterSurface* back_surface_;
+  fml::RefPtr<EmbedderSurfaceMetal> output_surface_;
+};
+
+// Creates PlatformOverlayMac instances, adding CALayer sublayers to the
+// provided overlay_layer (LynxOverlayView.layer).
+class PlatformOverlayServiceMac final : public PlatformOverlayService {
+ public:
+  // overlay_layer is LynxOverlayView.layer — the parent for all overlay sublayers.
+  static std::shared_ptr<PlatformOverlayServiceMac> CreateMac(
+      id<MTLDevice> device,
+      id<MTLCommandQueue> command_queue,
+      CALayer* overlay_layer,
+      CGFloat initial_scale);
+
+  std::vector<std::shared_ptr<PlatformOverlay>> CreatePlatformOverlay(
+      size_t num) override;
+
+ private:
+  PlatformOverlayServiceMac(id<MTLDevice> device,
+                             id<MTLCommandQueue> command_queue,
+                             CALayer* overlay_layer,
+                             CGFloat initial_scale);
+
+  id<MTLDevice> device_;
+  id<MTLCommandQueue> command_queue_;
+  CALayer* overlay_layer_;
+  CGFloat initial_scale_;
+};
+
+}  // namespace clay
+
+#endif  // CLAY_SHELL_PLATFORM_DARWIN_MACOS_PLATFORM_OVERLAY_SERVICE_MAC_H_
diff --git a/clay/shell/platform/darwin/macos/framework/Source/platform_overlay_service_mac.mm b/clay/shell/platform/darwin/macos/framework/Source/platform_overlay_service_mac.mm
new file mode 100644
index 00000000..338c81b2
--- /dev/null
+++ b/clay/shell/platform/darwin/macos/framework/Source/platform_overlay_service_mac.mm
@@ -0,0 +1,134 @@
+// Copyright 2025 The Lynx Authors. All rights reserved.
+// Licensed under the Apache License Version 2.0 that can be found in the
+// LICENSE file in the root directory of this source tree.
+
+#import "clay/shell/platform/darwin/macos/framework/Source/platform_overlay_service_mac.h"
+
+#import <Cocoa/Cocoa.h>
+#import <IOSurface/IOSurface.h>
+
+#include "clay/fml/logging.h"
+#include "clay/shell/platform/embedder/embedder_surface_metal.h"
+
+namespace clay {
+
+// ---------------------------------------------------------------------------
+// PlatformOverlayMac
+// ---------------------------------------------------------------------------
+
+PlatformOverlayMac::PlatformOverlayMac(id<MTLDevice> device,
+                                       id<MTLCommandQueue> command_queue,
+                                       CALayer* layer)
+    : device_(device),
+      command_queue_(command_queue),
+      layer_(layer),
+      back_surface_(nil) {
+  // Upcast to base inside the class where private inheritance is accessible.
+  EmbedderSurfaceMetalDelegate* delegate = this;
+  output_surface_ = fml::MakeRefCounted<EmbedderSurfaceMetal>(delegate);
+}
+
+PlatformOverlayMac::~PlatformOverlayMac() {
+  // CALayer removal must be on the main thread.
+  CALayer* layer = layer_;
+  dispatch_async(dispatch_get_main_queue(), ^{
+    [layer removeFromSuperlayer];
+  });
+}
+
+void PlatformOverlayMac::UpdateLayerFrame(CGRect frame) {
+  layer_.frame = frame;
+}
+
+CGFloat PlatformOverlayMac::GetContentsScale() const {
+  return layer_.contentsScale;
+}
+
+fml::RefPtr<OutputSurface> PlatformOverlayMac::GetOutputSurface() const {
+  return output_surface_;
+}
+
+GPUMTLDeviceHandle PlatformOverlayMac::GetMTLDevice() const {
+  return (__bridge GPUMTLDeviceHandle)device_;
+}
+
+GPUMTLCommandQueueHandle PlatformOverlayMac::GetMTLCommandQueue() const {
+  return (__bridge GPUMTLCommandQueueHandle)command_queue_;
+}
+
+GPUMTLTextureInfo PlatformOverlayMac::GetMTLTexture(
+    const skity::Vec2& frame_size) const {
+  // Allocate a fresh IOSurface-backed texture for this frame.
+  CGSize size = CGSizeMake(frame_size.x, frame_size.y);
+  back_surface_ = [[FlutterSurface alloc] initWithSize:size device:device_];
+  return [back_surface_ asGPUMTLTextureInfo];
+}
+
+bool PlatformOverlayMac::PresentTexture(GPUMTLTextureInfo texture) const {
+  // Called on the platform (main) thread via the submit callback.
+  FlutterSurface* surface = [FlutterSurface fromGPUMTLTextureInfo:&texture];
+  if (!surface) {
+    return false;
+  }
+  layer_.contents = (__bridge id)surface.ioSurface;
+  return true;
+}
+
+bool PlatformOverlayMac::EnablePartialRepaint() const {
+  return false;
+}
+
+// ---------------------------------------------------------------------------
+// PlatformOverlayServiceMac
+// ---------------------------------------------------------------------------
+
+PlatformOverlayServiceMac::PlatformOverlayServiceMac(
+    id<MTLDevice> device,
+    id<MTLCommandQueue> command_queue,
+    CALayer* overlay_layer,
+    CGFloat initial_scale)
+    : device_(device),
+      command_queue_(command_queue),
+      overlay_layer_(overlay_layer),
+      initial_scale_(initial_scale) {}
+
+std::shared_ptr<PlatformOverlayServiceMac> PlatformOverlayServiceMac::CreateMac(
+    id<MTLDevice> device,
+    id<MTLCommandQueue> command_queue,
+    CALayer* overlay_layer,
+    CGFloat initial_scale) {
+  return std::shared_ptr<PlatformOverlayServiceMac>(
+      new PlatformOverlayServiceMac(device, command_queue, overlay_layer,
+                                    initial_scale));
+}
+
+std::vector<std::shared_ptr<PlatformOverlay>>
+PlatformOverlayServiceMac::CreatePlatformOverlay(size_t num) {
+  // CALayer creation and parenting must happen on the main thread.
+  __block std::vector<CALayer*> layers(num);
+  CALayer* parent = overlay_layer_;
+  CGFloat scale = initial_scale_;
+
+  dispatch_sync(dispatch_get_main_queue(), ^{
+    for (size_t i = 0; i < num; i++) {
+      CALayer* layer = [CALayer layer];
+      layer.opaque = NO;
+      layer.contentsGravity = kCAGravityTopLeft;
+      layer.contentsScale = scale;
+      layer.frame = parent.bounds;
+      layer.autoresizingMask = kCALayerWidthSizable | kCALayerHeightSizable;
+      [parent addSublayer:layer];
+      layers[i] = layer;
+    }
+  });
+
+  std::vector<std::shared_ptr<PlatformOverlay>> result;
+  result.reserve(num);
+  for (size_t i = 0; i < num; i++) {
+    result.push_back(
+        std::make_shared<PlatformOverlayMac>(device_, command_queue_, layers[i]));
+  }
+  return result;
+}
+
+}  // namespace clay
