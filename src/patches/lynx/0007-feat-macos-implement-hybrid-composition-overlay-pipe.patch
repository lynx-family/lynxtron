+@implementation LynxOverlayView {
+  NSArray<NSValue*>* _opaqueRects;
+}
+
+- (instancetype)initWithFrame:(NSRect)frameRect {
+  self = [super initWithFrame:frameRect];
+  if (self) {
+    _opaqueRects = @[];
+    // Opt into layer-backed rendering so that setContents: (Phase 2) works.
+    self.wantsLayer = YES;
+    self.layer.opaque = NO;
+
+    // Autoresize to track the parent view.
+    self.autoresizingMask = NSViewWidthSizable | NSViewHeightSizable;
+
+    // Do not clip content – a tooltip near a window edge should still be
+    // visible even if it extends slightly beyond the overlay frame.
+    self.layer.masksToBounds = NO;
+  }
+  return self;
+}
+
+- (BOOL)isOpaque {
+  return NO;
+}
+
+// Phase 1 debug rendering: draw a translucent green stripe along the top edge
+// so engineers can confirm the overlay is on top of native views.  This block
+// is compiled out in Release builds.
+- (void)drawRect:(NSRect)dirtyRect {
+#if DEBUG
+  [[NSColor colorWithRed:0.0 green:1.0 blue:0.0 alpha:0.15] set];
+  NSRect stripe = NSMakeRect(0, NSMaxY(self.bounds) - 4, self.bounds.size.width, 4);
+  NSRectFill(stripe);
+#endif
+}
+
+// ---------------------------------------------------------------------------
+// Hit-testing: pass through to underlying native views for areas that the
+// overlay does not paint.  Uses a CPU-side list of opaque rects updated by
+// the paint system (Phase 2) to avoid GPU readback on every mouse event.
+// In Phase 1 the list is always empty → all events pass through.
+// ---------------------------------------------------------------------------
+
+- (void)updateOpaqueRects:(NSArray<NSValue*>*)rects {
+  // Must be called on the main thread.
+  _opaqueRects = [rects copy];
+}
+
+// ---------------------------------------------------------------------------
+// Phase 4: High-DPI display migration (corner case C9)
+// When the window moves between Retina and non-Retina displays, AppKit calls
+// this method.  We update the layer contentsScale to match the new backing
+// scale factor so the overlay is not blurry on a non-Retina display or
+// over-scaled on a Retina one.
+// ---------------------------------------------------------------------------
+- (void)viewDidChangeBackingProperties {
+  [super viewDidChangeBackingProperties];
+  CGFloat scale = self.window ? self.window.backingScaleFactor : 1.0;
+  self.layer.contentsScale = scale;
+}
+
+- (NSView*)hitTest:(NSPoint)point {
+  // |point| is in the superview's coordinate space (same as for any NSView).
+  NSPoint local = [self convertPoint:point fromView:self.superview];
+  for (NSValue* val in _opaqueRects) {
+    if (NSPointInRect(local, [val rectValue])) {
+      // There is painted content here – let the overlay handle the event.
+      return [super hitTest:point];
+    }
+  }
+  // Transparent region – pass through to native views below.
+  return nil;
+}
+
+@end
