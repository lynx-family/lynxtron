--- a/clay/shell/common/services/compositor/compositor_service.cc
+++ b/clay/shell/common/services/compositor/compositor_service.cc
@@ -30,6 +30,19 @@ bool CompositorService::SubmitFrame(
     return background_frame->Submit();
   }
 
+  // Lazily re-query overlay/presenter services in case they were registered
+  // after OnInit() ran (timing race on startup).
+  if (!overlay_service_ || !presenter_service_) {
+    if (auto sm = service_manager_weak_.lock()) {
+      if (!overlay_service_) {
+        overlay_service_ = sm->GetService<PlatformOverlayService>();
