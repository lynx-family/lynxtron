+// LynxUIRenderer view hierarchy.  It will display Lynx-rendered content
+// (Phase 2: overlay framebuffer) that must appear above native views.
+//
+// Phase 1: The view is transparent with a debug-mode solid background so
+// the z-order can be verified visually before the framebuffer routing is
+// connected.
+//
+// Hit-testing: a CPU-side list of opaque rects is maintained.  Only those
+// regions return |self| from hitTest:; everywhere else returns nil so mouse
+// events fall through to native views below.
+@interface LynxOverlayView : NSView
+
+// Called whenever the overlay content changes (Phase 2: after each frame
+// present).  |rects| is an array of NSValue-wrapped NSRects describing the
+// painted, non-transparent regions of the overlay.  Used by hitTest: to
+// provide per-pixel event pass-through without GPU readback.
+- (void)updateOpaqueRects:(NSArray<NSValue*>*)rects;
+
+@end
