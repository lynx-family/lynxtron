   had_hybrid_composited_ = true;
 
   // TODO(haoyoufeng.aji) support external overlay views
@@ -41,8 +54,13 @@ bool CompositorService::SubmitFrame(
   std::unordered_map<int64_t, skity::Rect> view_rects;
 
   for (int64_t view_id : compositor_state->GetCompositionOrder()) {
-    view_rects[view_id] =
-        compositor_state->GetViewParams()[view_id]->finalBoundingRect();
+    // Only platform views have entries in view_params; overlay views do not.
+    auto& view_params = compositor_state->GetViewParams();
+    auto vp_it = view_params.find(view_id);
+    if (vp_it == view_params.end()) {
+      continue;
+    }
+    view_rects[view_id] = vp_it->second->finalBoundingRect();
   }
 
   std::unordered_map<int64_t, skity::Rect> overlay_layers = SliceViews(
@@ -52,7 +70,18 @@ bool CompositorService::SubmitFrame(
   // background frame must come first since it's the "current" surface
   background_frame->set_submit_info({.present_with_transaction = true});
   did_encode &= background_frame->Encode();
-  submit_infos.push_back(background_frame->PrepareSubmit());
+  // NOTE: The background frame submit is NOT added to submit_infos.  It is
+  // executed on the raster thread below.  FlutterSurfaceManager::present:
+  // is documented as "Must be called on raster thread": it schedules a CALayer
+  // commit on the main thread and then blocks via
+  // FlutterThreadSynchronizer::performCommit.  If called from the platform
+  // (main) thread – as happens when submit_infos are executed inside
+  // PresenterService::Present – performCommit dispatches back to the main
+  // queue and then blocks the main thread waiting for that dispatch, causing
+  // a permanent deadlock (ANR).  Overlay frame submits use
+  // PlatformOverlayMac::PresentTexture which just sets layer_.contents
+  // directly and is safe to call from the platform thread.
+  auto background_submit = background_frame->PrepareSubmit();
 
   size_t required_overlay_layers = 0;
   for (int64_t view_id : compositor_state->GetCompositionOrder()) {
@@ -112,6 +141,21 @@ bool CompositorService::SubmitFrame(
       RemoveUnusedSurfaces();
   RecycleSurfaces();
 
+  // Execute the background frame submit on the raster thread before posting to
+  // the platform thread.  FlutterSurfaceManager::present:notify: must be
+  // called from the raster thread (see header comment); it internally calls
+  // FlutterThreadSynchronizer::performCommit which schedules the CALayer commit
+  // on the main thread and blocks the raster thread until it completes.
+  if (did_encode) {
+    const auto& [bg_cb, bg_info] = background_submit;
+    if (bg_cb) {
+      bg_cb(bg_info);
+    }
+  }
+
+  // submit_infos now contains only overlay frame callbacks
+  // (PlatformOverlayMac::PresentTexture), which directly set layer_.contents
+  // and are safe to call from the platform thread.
   PresentFrame present_frame{
       .overlays = std::move(platform_overlays),
       .compositor_params = std::move(compositor_state->GetViewParams()),
@@ -122,8 +166,8 @@ bool CompositorService::SubmitFrame(
 
   presenter_service_.Act([did_encode, present_frame = std::move(present_frame)](
                              auto& impl) mutable {
-    // We do `did_encode` check here because present_frame needs to be
-    // destructed in Platform thread
+    // present_frame must be destructed on the platform thread (contains
+    // ObjC objects whose lifetime must not cross thread boundaries).
     if (did_encode) {
       impl.Present(present_frame);
     }
@@ -135,8 +179,13 @@ bool CompositorService::SubmitFrame(
 // |clay::Service|
 void CompositorService::OnInit(clay::ServiceManager& service_manager,
                                const clay::RasterServiceContext& ctx) {
-  presenter_service_ = service_manager.GetService<PresenterService>();
-  overlay_service_ = service_manager.GetService<PlatformOverlayService>();
+  // Do NOT call GetService<PlatformOverlayService/PresenterService> here.
+  // Those services are registered by LynxUIRenderer on the main thread via
+  // RegisterService(), which runs after this OnInit (raster thread races ahead
+  // at startup). Calling GetService early would invoke Create() and store a
+  // stub entry, causing FML_DCHECK(inserted) to fire when RegisterService
+  // is later called. Instead, store a weak_ptr and let SubmitFrame lazy-query.
+  service_manager_weak_ = service_manager.shared_from_this();
   raster_task_runner_ = service_manager.GetTaskRunners()
                             ->SelectTaskRunner<clay::Owner::kRaster>();
 }
@@ -145,6 +194,7 @@ void CompositorService::OnDestroy() {
   presenter_service_ = nullptr;
   overlay_service_ = nullptr;
   raster_task_runner_ = nullptr;
+  service_manager_weak_.reset();
   compositor_surfaces_.clear();
 }
 
