{
  "name": "@lynx-js/lynx-library-headers",
  "author": "Lynxtron Authors",
  "version": "0.0.1",
  "type": "module",
  "description": "Lynx embedder C/C++ API and weak N-API headers for native libraries",
  "scripts": {
    "copy-headers": "node scripts/copy-headers.cjs",
