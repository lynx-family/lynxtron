{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Lynxtron: Debug",
      "request": "launch",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "type": "cppdbg",
      "environment": [],
      "externalConsole": false,
      "osx": {
        "program": "${workspaceFolder}/out/Debug/lynxtron.app",
        "type": "cppdbg",
        "MIMode": "lldb",
        "setupCommands": [
          {
            "description": "Source lldbinit.py",
            "text": "command script import ${workspaceFolder}/tools/lldb/lldbinit.py",
            "ignoreFailures": false
          },
          {
            "description": "Enable pretty-printing for gdb",
            "text": "-enable-pretty-printing",
            "ignoreFailures": true
          }
        ]
      },
      "windows": {
        "type": "cppvsdbg",
        "program": "${workspaceFolder}/out/Debug/lynxtron.exe",
        "console": "externalTerminal"
      }
    },
    {
      "name": "Attach to Process",
      "type": "cppdbg",
      "request": "attach",
      "processId": "${command:pickProcess}",
      "osx": {
        "MIMode": "lldb",
        "setupCommands": [
          {
            "description": "Source lldbinit.py",
            "text": "command script import ${workspaceFolder}/tools/lldb/lldbinit.py",
            "ignoreFailures": false
          }
        ]
      },
      "windows": {
        "type": "cppvsdbg"
      }
    }
  ]
}
