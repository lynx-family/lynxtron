{
  "name": "lynxtron-shell-demo",
  "author": "Lynxtron Authors",
  "version": "0.0.1",
  "type": "module",
  "description": "A minimal Lynxtron application",
  "main": "main.js",
  "scripts": {
    "build": "rspeedy build && rspack build",
    "start": "npm run build && lynxtron ./dist/assets",
    "dev": "cross-env NODE_ENV=development bash -c 'rspeedy dev & dev-ready-speedy && rspack build && lynxtron ./dist/assets'",
    "test": "vitest run",
    "pack": "npm run build && lynxtron-builder --publish never"
  },
  "private": true,
  "devDependencies": {
    "@electron/universal": "1.0.4",
    "@lynx-js/dev-ready-rsbuild-plugin": "workspace:*",
    "@lynx-js/lynxtron": "workspace:*",
    "@lynx-js/lynxtron-builder": "workspace:*",
    "@lynx-js/preact-devtools": "^5.0.1-c0c936b",
    "@lynx-js/qrcode-rsbuild-plugin": "^0.4.3",
    "@lynx-js/react": "0.115.4",
    "@lynx-js/react-rsbuild-plugin": "^0.12.5",
    "@lynx-js/rspeedy": "^0.13.0",
    "@lynx-js/types": "3.6.0",
    "@rsbuild/plugin-type-check": "1.3.1",
    "@rspack/cli": "^1.6.7",
    "@rspack/core": "^1.6.7",
    "@testing-library/jest-dom": "^6.9.0",
    "@types/react": "^18.3.25",
    "compressing": "^1.10.0",
    "cross-env": "^10.1.0",
    "jsdom": "^26.1.0",
    "npm-run-all": "^4.1.5",
    "typescript": "~5.9.3",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.3"
  },
  "engines": {
    "node": ">=18"
  }
}
