{
  "name": "@lynx-js/extension-builder",
  "author": "Lynxtron Authors",
  "version": "0.0.1",
  "type": "module",
  "description": "Lynx extension builder utils",
  "bin": "./scripts/scaffold.cjs",
  "scripts": {
    "prepublishOnly": "node scripts/prepublish.cjs",
    "postinstall": "node scripts/prepare.js",
    "scaffold": "node scripts/scaffold.cjs"
  },
  "keywords": [
    "lynx",
    "extension",
    "builder"
  ],
  "files": [
    "include/**/*",
    "module/**/*",
    "bindings/**/*",
    "index.cjs",
    "CMakeLists.txt",
    "README.md",
    "scripts/**/*"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@lynx-js/lynxtron": "workspace:*",
    "@lynx-js/weak-node-api": "0.0.2",
    "node-addon-api": "^7.0.0"
  }
}
